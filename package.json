{
    "name": "bitquran",
    "version": "1.2.0",
    "description": "Aplikasi Qur'an Berbasis Web – Baca Al-Qur'an secara Daring",
    "keywords": [
        "alquran",
        "al-quran",
        "alquran-web",
        "quran",
        "quran-web"
    ],
    "author": "Ahmad Rivaldy S",
    "license": "ISC",
    "type": "module",
    "private": true,
    "homepage": "https://bitquran.net",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rivaldys/bitquran.git"
    },
    "bugs": {
        "url": "https://github.com/rivaldys/bitquran/issues"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/react-query": "^5.100.14",
        "axios": "^1.16.1",
        "class-variance-authority": "^0.7.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-router": "^7.16.0",
        "tailwindcss": "^4.3.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^24.12.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.7",
        "@vitest/ui": "^4.1.7",
        "eslint": "^10.3.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "jsdom": "^29.1.1",
        "oxfmt": "^0.52.0",
        "oxlint": "^1.67.0",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.12",
        "vitest": "^4.1.7"
